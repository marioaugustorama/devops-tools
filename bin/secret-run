#!/bin/bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
Uso:
  secret-run <ENV_VAR> <bw args...> -- <comando> [args...]

Exemplo:
  secret-run DB_PASSWORD get password "meu-item" -- env | grep DB_PASSWORD
  secret-run AWS_TOKEN get notes "aws-token" -- ./script.sh
EOF
}

if [ $# -lt 4 ]; then
  usage
  exit 1
fi

env_var=$1
shift

if ! [[ "$env_var" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]; then
  echo "Nome de variável inválido: $env_var" >&2
  exit 1
fi

bw_args=()
while [ $# -gt 0 ]; do
  if [ "$1" = "--" ]; then
    shift
    break
  fi
  bw_args+=("$1")
  shift
done

if [ ${#bw_args[@]} -eq 0 ] || [ $# -eq 0 ]; then
  usage
  exit 1
fi

if ! command -v bw >/dev/null 2>&1; then
  echo "Comando 'bw' não encontrado. Instale com pkg_add install bitwarden." >&2
  exit 1
fi

secret=$(bw "${bw_args[@]}" 2>/dev/null | tr -d '\r')
if [ -z "${secret:-}" ]; then
  echo "Falha ao obter segredo com bw. Verifique login/sessão (BW_SESSION)." >&2
  exit 1
fi

exec env "${env_var}=${secret}" "$@"
