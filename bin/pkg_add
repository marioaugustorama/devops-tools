#!/bin/bash
set -euo pipefail
shopt -s nullglob

# Diretório onde estão localizados os scripts
if [ -n "${SCRIPTS_DIR:-}" ]; then
  SCRIPTS_DIR="$SCRIPTS_DIR"
elif [ -d "/usr/local/scripts" ]; then
  SCRIPTS_DIR="/usr/local/scripts"
else
  SCRIPTS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../scripts" && pwd)"
fi
PKG_INDEX="${PKG_INDEX:-$SCRIPTS_DIR/packages.tsv}"
COMMANDS_INDEX="${COMMANDS_INDEX:-$SCRIPTS_DIR/commands.tsv}"
STATE_FILE_DEFAULT="/var/lib/devops-pkg/installed.list"
STATE_FILE="${STATE_FILE:-$STATE_FILE_DEFAULT}"
PKG_REMOTE_INDEX="${PKG_REMOTE_INDEX:-}"
PKG_REMOTE_SCRIPTS_DIR="${PKG_REMOTE_SCRIPTS_DIR:-}"

if [ -f /usr/local/bin/utils.sh ]; then
  # shellcheck disable=SC1091
  source /usr/local/bin/utils.sh
elif [ -f "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../utils.sh" ]; then
  # shellcheck disable=SC1091
  source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../utils.sh"
fi

AVAILABLE=()
declare -A PKG_DESC
declare -A PKG_GROUP
declare -A PKG_DEFAULT

usage() {
  cat >&2 <<EOF
Uso: $0 <comando> [opções]

Comandos:
  list [--installed] [--group <grupo>]
                       Lista pacotes disponíveis (ou só os instalados)
  groups               Lista grupos disponíveis no manifesto
  status               Lista pacotes e se já foram instalados via pkg_add
  version              Mostra versão da imagem/ambiente
  info <pacote>        Mostra detalhes de um pacote
  suggest [--raw|--tsv] <comando>
                       Sugere pacote para um comando não encontrado
  install [--all] [--group <grupo>] [--force] <pacote> [pacote...]
                       Instala pacotes específicos, todos (--all) ou por grupo
  disable <pacote>...  Marca pacotes como desabilitados (remove da lista instalada)
  update               Atualiza manifestos/scripts a partir de repositório remoto (se configurado)

Variáveis úteis:
  SCRIPTS_DIR (padrão: /usr/local/scripts)
  PKG_INDEX   (padrão: \$SCRIPTS_DIR/packages.tsv)
  COMMANDS_INDEX (padrão: \$SCRIPTS_DIR/commands.tsv)
  STATE_FILE  (padrão: /var/lib/devops-pkg/installed.list)
  PKG_REMOTE_INDEX        URL opcional do manifest (packages.tsv) remoto
  PKG_REMOTE_SCRIPTS_DIR  URL base opcional para baixar scripts (*.sh)
EOF
}

try_run_sudo() {
  if [ "$EUID" -eq 0 ]; then
    "$@"
  elif command -v sudo >/dev/null 2>&1; then
    if sudo -n true 2>/dev/null; then
      sudo "$@"
    else
      echo "Aviso: sudo pede senha, tentando sem sudo..." >&2
      "$@"
    fi
  else
    "$@"
  fi
}

normalize_bool() {
  local value="${1:-}"
  value=$(echo "$value" | tr '[:upper:]' '[:lower:]')
  case "$value" in
    1|true|yes|y|on|sim) echo "1" ;;
    0|false|no|n|off|nao|não) echo "0" ;;
    *) echo "0" ;;
  esac
}

append_unique() {
  local value="$1"
  shift || true
  for item in "$@"; do
    [ "$item" = "$value" ] && return 0
  done
  return 1
}

load_packages() {
  AVAILABLE=()
  PKG_DESC=()
  PKG_GROUP=()
  PKG_DEFAULT=()

  if [ -f "$PKG_INDEX" ]; then
    while IFS=$'\t' read -r name desc group default_install; do
      [[ -z "${name:-}" || "${name:0:1}" == "#" ]] && continue
      group="${group:-general}"
      default_install="${default_install:-1}"

      AVAILABLE+=("$name")
      PKG_DESC["$name"]="${desc:-$name}"
      PKG_GROUP["$name"]="$group"
      PKG_DEFAULT["$name"]="$(normalize_bool "$default_install")"
    done < "$PKG_INDEX"
  fi

  if [ ${#AVAILABLE[@]} -eq 0 ]; then
    for script in "$SCRIPTS_DIR"/*.sh; do
      name=$(basename -- "$script")
      name="${name%.*}"
      AVAILABLE+=("$name")
      PKG_DESC["$name"]="$name"
      PKG_GROUP["$name"]="general"
      PKG_DEFAULT["$name"]="1"
    done
  fi
}

ensure_state_file() {
  local target="$STATE_FILE"
  local dir
  dir=$(dirname "$target")
  if try_run_sudo mkdir -p "$dir" && try_run_sudo touch "$target"; then
    return
  fi

  if [ "$target" = "$STATE_FILE_DEFAULT" ]; then
    local fallback="${HOME:-/tmp}/.devops-pkg/installed.list"
    echo "Aviso: sem permissão para usar $STATE_FILE. Usando $fallback" >&2
    STATE_FILE="$fallback"
    dir=$(dirname "$STATE_FILE")
    mkdir -p "$dir" && touch "$STATE_FILE"
  else
    echo "Erro: não foi possível criar o arquivo de estado em $STATE_FILE" >&2
    exit 1
  fi
}

is_marked_installed() {
  ensure_state_file
  grep -Fxq "$1" "$STATE_FILE" 2>/dev/null
}

mark_installed() {
  ensure_state_file
  if ! grep -Fxq "$1" "$STATE_FILE"; then
    echo "$1" >> "$STATE_FILE"
  fi
}

require_packages_exist() {
  local missing=()
  for pkg in "$@"; do
    if [ ! -f "$SCRIPTS_DIR/$pkg.sh" ]; then
      missing+=("$pkg")
    fi
  done
  if [ ${#missing[@]} -gt 0 ]; then
    echo "Pacote(s) não encontrados em $SCRIPTS_DIR: ${missing[*]}" >&2
    exit 1
  fi
}

is_in_group_filter() {
  local pkg_group="$1"
  local selected_groups="${2:-}"
  [ -z "$selected_groups" ] && return 0

  IFS=',' read -r -a groups <<< "$selected_groups"
  for group in "${groups[@]}"; do
    group="$(echo "$group" | xargs)"
    [ -z "$group" ] && continue
    [ "$pkg_group" = "$group" ] && return 0
  done
  return 1
}

print_list() {
  load_packages
  local only_installed=false
  local group_filter=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --installed) only_installed=true ;;
      --group)
        shift
        group_filter="${1:-}"
        [ -n "$group_filter" ] || { echo "Uso: $0 list [--installed] [--group <grupo>]" >&2; exit 1; }
        ;;
      *)
        echo "Opção inválida para list: $1" >&2
        echo "Uso: $0 list [--installed] [--group <grupo>]" >&2
        exit 1
        ;;
    esac
    shift
  done

  local count=0
  for pkg in "${AVAILABLE[@]}"; do
    is_in_group_filter "${PKG_GROUP[$pkg]}" "$group_filter" || continue
    if $only_installed; then
      is_marked_installed "$pkg" || continue
    fi
    count=$((count+1))
  done

  if $only_installed; then
    printf -- "Pacotes instalados (%d):\n" "$count"
  else
    printf -- "Pacotes disponíveis (%d):\n" "$count"
  fi

  for pkg in "${AVAILABLE[@]}"; do
    is_in_group_filter "${PKG_GROUP[$pkg]}" "$group_filter" || continue
    if $only_installed && ! is_marked_installed "$pkg"; then
      continue
    fi
    local default_label="on-demand"
    [ "${PKG_DEFAULT[$pkg]}" = "1" ] && default_label="default"
    printf -- "- %-16s [%s|%s] %s\n" "$pkg" "${PKG_GROUP[$pkg]}" "$default_label" "${PKG_DESC[$pkg]}"
  done
}

print_groups() {
  load_packages
  local groups
  groups=$(for pkg in "${AVAILABLE[@]}"; do echo "${PKG_GROUP[$pkg]}"; done | sort -u)
  if [ -z "$groups" ]; then
    echo "Nenhum grupo encontrado."
    return
  fi
  echo "Grupos disponíveis:"
  echo "$groups" | while IFS= read -r group; do
    [ -z "$group" ] && continue
    local count=0
    for pkg in "${AVAILABLE[@]}"; do
      [ "${PKG_GROUP[$pkg]}" = "$group" ] && count=$((count+1))
    done
    printf -- "- %s (%d pacote(s))\n" "$group" "$count"
  done
}

print_status() {
  load_packages
  printf -- "Status dos pacotes:\n"
  for pkg in "${AVAILABLE[@]}"; do
    local default_label="on-demand"
    [ "${PKG_DEFAULT[$pkg]}" = "1" ] && default_label="default"
    if is_marked_installed "$pkg"; then
      printf -- "[instalado] %-14s [%s|%s] %s\n" "$pkg" "${PKG_GROUP[$pkg]}" "$default_label" "${PKG_DESC[$pkg]}"
    else
      printf -- "[pendente ] %-14s [%s|%s] %s\n" "$pkg" "${PKG_GROUP[$pkg]}" "$default_label" "${PKG_DESC[$pkg]}"
    fi
  done
}

print_info() {
  load_packages
  local pkg="${1:-}"
  if [ -z "$pkg" ]; then
    echo "Uso: $0 info <pacote>" >&2
    exit 1
  fi
  require_packages_exist "$pkg"
  local desc="${PKG_DESC[$pkg]:-$pkg}"
  local group="${PKG_GROUP[$pkg]:-general}"
  local default_install="${PKG_DEFAULT[$pkg]:-1}"
  local script_path="$SCRIPTS_DIR/$pkg.sh"
  local status="pendente"
  local default_label="não"
  [ "$default_install" = "1" ] && default_label="sim"
  if is_marked_installed "$pkg"; then
    status="instalado"
  fi
  cat <<EOF
Pacote:      $pkg
Descrição:   $desc
Grupo:       $group
Default:     $default_label (instala no build padrão)
Script:      $script_path
Status:      $status (via pkg_add)
EOF
}

install_packages() {
  local force=false all=false
  local group_filter=""
  local args=()

  while [ $# -gt 0 ]; do
    case "$1" in
      --force|-f) force=true ;;
      --all) all=true ;;
      --group)
        shift
        group_filter="${1:-}"
        [ -n "$group_filter" ] || { echo "Uso: $0 install [--all] [--group <grupo>] [--force] <pacote> [pacote...]" >&2; exit 1; }
        ;;
      *) args+=("$1") ;;
    esac
    shift
  done

  load_packages
  local targets=()

  if $all; then
    targets=("${AVAILABLE[@]}")
  elif [ -n "$group_filter" ]; then
    for pkg in "${AVAILABLE[@]}"; do
      is_in_group_filter "${PKG_GROUP[$pkg]}" "$group_filter" || continue
      targets+=("$pkg")
    done
  fi

  for requested in "${args[@]}"; do
    if ! append_unique "$requested" "${targets[@]}"; then
      targets+=("$requested")
    fi
  done

  if [ ${#targets[@]} -eq 0 ]; then
    echo "Uso: $0 install [--all] [--group <grupo>] [--force] <pacote> [pacote...]" >&2
    exit 1
  fi

  require_packages_exist "${targets[@]}"

  for pkg in "${targets[@]}"; do
    local script_path="$SCRIPTS_DIR/$pkg.sh"
    if is_marked_installed "$pkg" && ! $force; then
      echo "Pulando $pkg (já marcado como instalado). Use --force para reinstalar."
      continue
    fi
    echo "Instalando pacote: $pkg"
    try_run_sudo "$script_path"
    mark_installed "$pkg"
    echo "Pacote '$pkg' instalado."
  done
}

update_packages() {
  if [ -z "$PKG_REMOTE_INDEX" ] || [ -z "$PKG_REMOTE_SCRIPTS_DIR" ]; then
    echo "PKG_REMOTE_INDEX e PKG_REMOTE_SCRIPTS_DIR não configurados. Nada a fazer." >&2
    exit 1
  fi
  mkdir -p "$SCRIPTS_DIR"
  echo "Baixando manifesto de pacotes..."
  curl -fLs "$PKG_REMOTE_INDEX" -o "$PKG_INDEX"
  echo "Manifesto atualizado em $PKG_INDEX"

  while IFS=$'\t' read -r name _; do
    [[ -z "${name:-}" || "${name:0:1}" == "#" ]] && continue
    url="${PKG_REMOTE_SCRIPTS_DIR}/${name}.sh"
    dest="$SCRIPTS_DIR/${name}.sh"
    echo "Baixando ${name}.sh..."
    curl -fLs "$url" -o "$dest"
    chmod +x "$dest"
  done < "$PKG_INDEX"
  echo "Scripts atualizados em $SCRIPTS_DIR"
}

disable_packages() {
  if [ $# -eq 0 ]; then
    echo "Uso: $0 disable <pacote> [pacote...]" >&2
    exit 1
  fi

  load_packages
  require_packages_exist "$@"
  ensure_state_file

  local tmp filtered
  tmp=$(mktemp)
  filtered=$(mktemp)

  if ! cat "$STATE_FILE" > "$tmp" 2>/dev/null; then
    try_run_sudo cat "$STATE_FILE" > "$tmp" || { echo "Erro ao ler $STATE_FILE" >&2; exit 1; }
  fi

  local disabled_any=false
  while IFS= read -r line; do
    local skip=false
    for pkg in "$@"; do
      if [ "$line" = "$pkg" ]; then
        skip=true
        disabled_any=true
        break
      fi
    done
    $skip || printf "%s\n" "$line" >> "$filtered"
  done < "$tmp"

  if ! try_run_sudo install -m 0644 "$filtered" "$STATE_FILE"; then
    install -m 0644 "$filtered" "$STATE_FILE"
  fi

  rm -f "$tmp" "$filtered"

  if $disabled_any; then
    echo "Pacote(s) desabilitado(s). Eles não serão considerados 'instalados' em futuras execuções (não remove binários)."
  else
    echo "Nenhum pacote listado estava marcado como instalado."
  fi
}

print_version() {
  local version_value=""

  if [ -n "${APP_VERSION:-}" ] && [ "${APP_VERSION}" != "unknown" ]; then
    version_value="${APP_VERSION}"
  elif [ -f /etc/version ]; then
    version_value="$(cat /etc/version 2>/dev/null || true)"
  fi

  if [ -z "$version_value" ] && [ -f "$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/version" ]; then
    version_value="$(cat "$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/version" 2>/dev/null || true)"
  fi

  [ -n "$version_value" ] || version_value="unknown"
  echo "$version_value"
}

suggest_package_command() {
  local output_mode="human"
  local cmd=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --raw) output_mode="raw" ;;
      --tsv) output_mode="tsv" ;;
      --help|-h)
        echo "Uso: $0 suggest [--raw|--tsv] <comando>" >&2
        return 2
        ;;
      *)
        if [ -z "$cmd" ]; then
          cmd="$1"
        else
          echo "Uso: $0 suggest [--raw|--tsv] <comando>" >&2
          return 2
        fi
        ;;
    esac
    shift
  done

  if [ -z "$cmd" ]; then
    echo "Uso: $0 suggest [--raw|--tsv] <comando>" >&2
    return 2
  fi

  if ! command -v suggest_package_for_command >/dev/null 2>&1; then
    [ "$output_mode" = "human" ] && echo "Sugestão indisponível: função suggest_package_for_command não carregada." >&2
    return 1
  fi

  if [ ! -f "$COMMANDS_INDEX" ]; then
    if [ "$output_mode" = "human" ]; then
      echo "Sugestão indisponível: índice de comandos não encontrado em '$COMMANDS_INDEX'." >&2
      echo "Rebuild da imagem necessário para incluir scripts/commands.tsv." >&2
    fi
    return 1
  fi

  if suggest_package_for_command "$cmd" "$output_mode"; then
    return 0
  fi

  [ "$output_mode" = "human" ] && echo "Nenhuma sugestão encontrada para '$cmd'." >&2
  return 1
}

if [ $# -lt 1 ]; then
  usage; exit 1
fi

COMMAND="$1"; shift || true

case "$COMMAND" in
  list)
    print_list "$@"
    ;;
  groups)
    print_groups
    ;;
  status)
    print_status
    ;;
  version)
    print_version
    ;;
  info)
    print_info "$@"
    ;;
  suggest)
    suggest_package_command "$@"
    ;;
  install)
    install_packages "$@"
    ;;
  disable)
    disable_packages "$@"
    ;;
  update)
    update_packages
    ;;
  *)
    usage; exit 1 ;;
esac
